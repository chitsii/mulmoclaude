FROM node:22-slim
RUN npm install -g @anthropic-ai/claude-code tsx \
 && useradd --create-home --shell /bin/bash claude \
 && mkdir -p /workspace /home/claude/.claude \
 && chown -R claude:claude /workspace /home/claude
WORKDIR /app
COPY package.json yarn.lock ./
RUN yarn install --production --ignore-scripts 2>/dev/null; exit 0
COPY server/ ./server/
COPY src/config/ ./src/config/
COPY src/plugins/ ./src/plugins/
ENV HOME=/home/claude
WORKDIR /workspace
USER claude
